<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Регистрация - Voice Chat</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #1a1b1e 0%, #2f3136 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .register-container {
      width: 100%;
      max-width: 480px;
    }

    .register-card {
      background: #2f3136;
      border-radius: 8px;
      padding: 32px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
      animation: fadeIn 0.3s ease;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .logo {
      text-align: center;
      margin-bottom: 32px;
    }

    .logo-icon {
      font-size: 48px;
      margin-bottom: 12px;
    }

    .logo h1 {
      font-size: 24px;
      font-weight: 600;
      color: #ffffff;
      margin-bottom: 8px;
    }

    .logo p {
      font-size: 14px;
      color: #8e9297;
    }

    .form-group {
      margin-bottom: 20px;
    }

    .form-group label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: #b5bac1;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .form-group input {
      width: 100%;
      padding: 12px 16px;
      background: #202225;
      border: 1px solid #202225;
      border-radius: 4px;
      color: #ffffff;
      font-size: 16px;
      transition: all 0.2s;
    }

    .form-group input:focus {
      outline: none;
      border-color: #5865f2;
    }

    .form-group input::placeholder {
      color: #4e5058;
    }

    .register-btn {
      width: 100%;
      padding: 12px;
      background: #5865f2;
      border: none;
      border-radius: 4px;
      color: #ffffff;
      font-size: 16px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 8px;
    }

    .register-btn:hover {
      background: #4752c4;
    }

    .login-link {
      text-align: center;
      margin-top: 20px;
      font-size: 14px;
      color: #8e9297;
    }

    .login-link a {
      color: #5865f2;
      text-decoration: none;
      font-weight: 500;
    }

    .login-link a:hover {
      text-decoration: underline;
    }

    .error-message {
      background: #ed4245;
      color: #ffffff;
      padding: 10px 16px;
      border-radius: 4px;
      font-size: 14px;
      margin-bottom: 20px;
      text-align: center;
    }

    .requirements {
      font-size: 12px;
      color: #8e9297;
      margin-top: 8px;
    }
  </style>
</head>
<body>
  <div class="register-container">
    <div class="register-card">
      <div class="logo">
        <div class="logo-icon">logo</div>
        <h1>Создать аккаунт</h1>
        <p>Присоединяйтесь к голосовому чату</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-message"><%= error %></div>
      <% } %>

      <form action="/register" method="POST">
        <div class="form-group">
          <label>ИМЯ ПОЛЬЗОВАТЕЛЯ</label>
          <input type="text" name="username" placeholder="Введите имя пользователя" required minlength="3" maxlength="32">
          <div class="requirements">От 3 до 32 символов</div>
        </div>

        <div class="form-group">
          <label>ПАРОЛЬ</label>
          <input type="password" name="password" placeholder="Введите пароль" required minlength="6">
          <div class="requirements">Минимум 6 символов</div>
        </div>

        <button type="submit" class="register-btn">Зарегистрироваться</button>
      </form>

      <div class="login-link">
        Уже есть аккаунт? <a href="/login">Войти</a>
      </div>
    </div>
  </div>
</body>
</html>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>Voice Chat</title>
  <link rel="stylesheet" href="/css/discord-style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="/socket.io/socket.io.js"></script>
</head>
<body>
  <script>
    window.initialGroups = <%- JSON.stringify(groups) %>;
    window.currentUserId = '<%- user._id %>';
    window.currentUsername = '<%- user.username %>';
  </script>

  <div class="app">
    <!-- LEFT PANEL (общий контейнер) -->
    <div class="left-panel">
      <!-- Верхняя часть: серверы + каналы -->
      <div class="top-panel">
        <!-- Левая панель серверов -->
        <div class="servers-bar">
          <div class="servers-list" id="servers-list"></div>
          <button class="add-server-btn" id="add-server-btn" title="Создать или присоединиться">
            <span>+</span>
          </button>
        </div>

        <!-- Правая панель каналов -->
        <div class="channels-panel" id="channels-panel" style="display: none;">
          <div class="channels-header">
            <div class="group-name" id="group-name-header"></div>
          </div>
          
          <div class="channels-section">
            <div class="section-header">
              <span class="section-title">КАНАЛЫ</span>
              <button class="add-channel-btn" id="add-channel-btn" style="display: none;">+</button>
            </div>
            <div class="channels-list" id="channels-list-panel"></div>
          </div>
        </div>
      </div>

      <!-- Бар с названием канала (появляется при входе в звонок) -->
      <!-- <div class="voice-call-bar" id="voice-call-bar" style="display: none;">
        <div class="call-bar-content">
          <span class="call-bar-icon">🔊</span>
          <span class="call-bar-name" id="call-bar-name"></span>
        </div>
        <button class="call-bar-leave-btn" id="call-bar-leave-btn" title="Покинуть канал">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.486 2 2 6.486 2 12s4.486 10 10 10 10-4.486 10-10S17.514 2 12 2zm0 18c-4.411 0-8-3.589-8-8s3.589-8 8-8 8 3.589 8 8-3.589 8-8 8z"/>
            <path d="M13 7h-2v6h2V7zm0 8h-2v2h2v-2z"/>
          </svg>
        </button>
      </div> -->

      <!-- Панель управления голосом (Liquid Glass стиль) -->
      <div class="voice-controls-left" id="voice-controls-left">
        <div class="voice-call-bar" id="voice-call-bar" style="display: none;">
          <div class="call-bar-content">
            <span class="call-bar-icon">🔊</span>
            <span class="call-bar-name" id="call-bar-name"></span>
          </div>
          <button class="call-bar-leave-btn" id="call-bar-leave-btn" title="Покинуть канал">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.486 2 2 6.486 2 12s4.486 10 10 10 10-4.486 10-10S17.514 2 12 2zm0 18c-4.411 0-8-3.589-8-8s3.589-8 8-8 8 3.589 8 8-3.589 8-8 8z"/>
              <path d="M13 7h-2v6h2V7zm0 8h-2v2h2v-2z"/>
            </svg>
          </button>
        </div>
        <div class="user-info">
          <div class="user-avatar" id="user-avatar">
            <span id="avatar-initial"><%- user.username.charAt(0).toUpperCase() %></span>
          </div>
          <div class="user-name" id="user-name"><%- user.username %></div>
        </div>
        <div class="control-buttons">
          <button class="control-btn mic-btn" id="mic-btn" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 16c-2.206 0-4-1.794-4-4V6c0-2.206 1.794-4 4-4s4 1.794 4 4v6c0 2.206-1.794 4-4 4zm8-4c0 4.411-3.589 8-8 8s-8-3.589-8-8h2c0 3.309 2.691 6 6 6s6-2.691 6-6h2z"/>
              <path d="M12 20c-3.309 0-6-2.691-6-6H4c0 4.411 3.589 8 8 8s8-3.589 8-8h-2c0 3.309-2.691 6-6 6z"/>
            </svg>
          </button>
          <button class="control-btn headphones-btn" id="headphones-btn" disabled>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 3C7.589 3 4 6.589 4 11v5c0 1.654 1.346 3 3 3h1v-8H6v-1c0-3.309 2.691-6 6-6s6 2.691 6 6v1h-2v8h1c1.654 0 3-1.346 3-3v-5c0-4.411-3.589-8-8-8zM9 19c-1.654 0-3-1.346-3-3v-2h2v5H9zm9-3c0 1.654-1.346 3-3 3h-1v-5h2v2h2v-2h2v2z"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Модальное окно выбора типа канала -->
    <div class="modal-overlay-channel-type" id="channel-type-modal" style="display: none;">
      <div class="modal-content channel-type-modal">
        <div class="modal-header">
          <h3>Создать канал</h3>
          <button class="modal-close" id="channel-type-modal-close">×</button>
        </div>
        <div class="channel-type-buttons">
          <button class="channel-type-btn" data-type="voice">
            <span class="channel-type-icon">🔊</span>
            <div class="channel-type-info">
              <div class="channel-type-title">Голосовой канал</div>
              <div class="channel-type-desc">Общайтесь голосом</div>
            </div>
          </button>
          <button class="channel-type-btn" data-type="text">
            <span class="channel-type-icon">💬</span>
            <div class="channel-type-info">
              <div class="channel-type-title">Текстовый канал</div>
              <div class="channel-type-desc">Общайтесь в чате</div>
            </div>
          </button>
        </div>
      </div>
    </div>

    <!-- ПРАВАЯ ПАНЕЛЬ (участники группы) -->
    

    <!-- ЦЕНТРАЛЬНАЯ ОБЛАСТЬ (список участников или чат) -->
    <div class="main-area">
      <!-- <div class="voice-container" id="voice-container">
        <div class="voice-users-header">В КАНАЛЕ — <span id="users-count">0</span></div>
        <div class="voice-users-list" id="voice-users-list"></div>
      </div> -->
    </div>

    <div class="members-panel" id="members-panel">
      <div class="members-header">
        <span class="members-title">УЧАСТНИКИ ГРУППЫ</span>
        <span class="members-count" id="members-count">0</span>
      </div>
      <div class="members-list" id="members-list">
        <!-- Динамически заполняется участниками группы -->
      </div>
    </div>

    <!-- Модальное окно создания/присоединения к группе -->
    <div class="modal-overlay" id="modal-overlay" style="display: none;">
      <div class="modal-content">
        <div class="modal-header">
          <h3>Создать сервер</h3>
          <button class="modal-close" id="modal-close">×</button>
        </div>
        <div class="modal-tabs">
          <button class="modal-tab active" data-tab="create">Создать</button>
          <button class="modal-tab" data-tab="join">Присоединиться</button>
        </div>
        
        <div class="modal-tab-content active" id="tab-create">
          <input type="text" id="new-group-name" placeholder="Название сервера" maxlength="100">
          <button class="modal-submit" id="create-group-submit">Создать</button>
        </div>
        
        <div class="modal-tab-content" id="tab-join">
          <input type="text" id="invite-code-input" placeholder="Код-приглашение">
          <button class="modal-submit" id="join-group-submit">Присоединиться</button>
        </div>
      </div>
    </div>

    <!-- Модальное окно создания канала (старое, оставляем для совместимости) -->
    <div class="modal-overlay-channel" id="channel-modal-overlay" style="display: none;">
      <div class="modal-content channel-modal">
        <div class="modal-header">
          <h3>Создать канал</h3>
          <button class="modal-close" id="channel-modal-close">×</button>
        </div>
        <div class="modal-tab-content active">
          <input type="text" id="new-channel-name" placeholder="Название канала" maxlength="50">
          <button class="modal-submit" id="create-channel-submit">Создать</button>
        </div>
      </div>
    </div>
  </div>
  
  <script src="/js/socket.js"></script>
  <script src="/js/webrtc.js"></script>
  <script src="/js/discord-ui.js"></script>
</body>
</html>